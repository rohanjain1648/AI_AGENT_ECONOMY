# Copy this to .env and fill in your values

# Anthropic API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# TokenRouter — optional, gives access to 50+ models + $200 free credits
# Get yours at https://tokenrouter.paleblueai.com
TOKENROUTER_API_KEY=

# Gmail OAuth — optional, enables real Gmail draft creation
# Download credentials.json from Google Cloud Console > APIs & Services > Credentials
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
